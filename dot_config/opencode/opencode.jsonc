{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "minimax/minimax-m2.7": {
          "options": {
            "provider": {
              "order": ["minimax/highspeed"]
            }
          }
        }
      }
    }
  }
}
